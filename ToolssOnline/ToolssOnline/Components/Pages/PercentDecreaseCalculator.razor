@page "/percent-decrease"
@using System.Globalization
@rendermode InteractiveServer



<div class="calculator-container">
    <h3 class="calculator-title">
        <i class="fas fa-arrow-down"></i> محاسبه درصد کاهش
    </h3>

    <div class="form-group">
        <label>درصد کاهش (%)</label>
        <InputNumber @bind-Value="percentage" class="form-control"
                     min="0" max="100" step="0.01" />
    </div>

    <div class="form-group">
        <label>عدد اولیه</label>
        <InputNumber @bind-Value="originalValue" class="form-control"
                     min="0" step="0.01" />
    </div>

    <div class="form-group">
        <label>مقدار کاهش (محاسبه شده)</label>
        <input type="text" value="@decreaseAmount.ToString("N2", CultureInfo.InvariantCulture)"
               class="form-control bg-light" readonly />
    </div>

    <div class="form-group">
        <label>عدد جدید (عدد اولیه - کاهش)</label>
        <input type="text" value="@newValue.ToString("N2", CultureInfo.InvariantCulture)"
               class="form-control bg-light" readonly />
    </div>

    <div class="button-group">
        <button class="btn btn-primary" @onclick="CalculateDecrease">
            <i class="fas fa-calculator"></i> محاسبه
        </button>
        <button class="btn btn-outline-secondary" @onclick="ResetFields">
            <i class="fas fa-redo"></i> ریست
        </button>
    </div>

    @if (showResult)
    {
        <div class="result-box">
            <i class="fas fa-result"></i> نتیجه: عدد جدید برابر است با @newValue.ToString("N2")
        </div>
    }
</div>

@code {
    private double percentage;
    private double originalValue;
    private double decreaseAmount;
    private double newValue;
    private bool showResult = false;

    private void CalculateDecrease()
    {
        if (originalValue <= 0 || percentage < 0 || percentage > 100)
            return;

        decreaseAmount = (originalValue * percentage) / 100.0;
        newValue = originalValue - decreaseAmount;
        showResult = true;
    }

    private void ResetFields()
    {
        percentage = 0;
        originalValue = 0;
        decreaseAmount = 0;
        newValue = 0;
        showResult = false;
    }
}
